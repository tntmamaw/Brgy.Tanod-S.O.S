rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Helper Functions
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Placeholder validation - should be more robust in production
    function isValidAlert(data) {
        return data.userId is string && data.clientName is string && data.status is string;
    }
    function isValidDutyLog(data) {
        return data.tanodName is string && data.dutyDate is string;
    }
    function isValidUser(data) {
        return data.email is string && data.role is string;
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(alertId) && isValidAlert(incoming());
      allow update: if isSignedIn() && isValidAlert(incoming());
    }

    match /dutyLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(logId) && isValidDutyLog(incoming());
    }
  }
}
