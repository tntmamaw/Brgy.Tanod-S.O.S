rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth Token Integrity
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    
    // Role Helpers (Cached or Relational)
    function isMasterAdmin() { 
      return isSignedIn() && request.auth.token.email == 'rubenlleg12@gmail.com';
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() { 
      return isSignedIn() && (
        isMasterAdmin() || 
        (getUserData() != null && getUserData().role == 'admin')
      );
    }
    
    function isTanod() { 
      return isSignedIn() && (
        isAdmin() || 
        (getUserData() != null && getUserData().role == 'tanod')
      );
    }
    
    function isResident() { 
      return isSignedIn() && (
        isMasterAdmin() || 
        (getUserData() == null || getUserData().role == 'resident')
      );
    }

    // ==========================================
    // VALIDATION BLUEPRINTS
    // ==========================================

    function isValidResidentProfile(data) {
      return data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 200 &&
             (data.age is number || data.age is string) &&
             data.gender in ['Male', 'Female', 'Other'] &&
             data.mobileNumber is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.gpsLat is number && data.gpsLng is number &&
             data.keys().hasAll(['fullName', 'age', 'gender', 'mobileNumber', 'gpsLat', 'gpsLng', 'status', 'uid', 'registeredAt']) &&
             data.keys().size() >= 9;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() <= 200 &&
             data.role in ['resident', 'tanod', 'admin'] &&
             data.email is string &&
             data.keys().hasAll(['uid', 'name', 'role', 'email', 'createdAt']) &&
             data.keys().size() <= 10;
    }

    function isValidAlert(data) {
      return data.residentId == request.auth.uid &&
             data.residentName is string &&
             data.type in ['medical', 'fire', 'crime', 'flood', 'violence', 'other', 'disturbance'] &&
             data.location.lat is number && data.location.lng is number &&
             data.status in ['pending', 'responding', 'resolved', 'cancelled'] &&
             data.timestamp is string &&
             data.keys().hasAll(['residentId', 'residentName', 'type', 'location', 'status', 'timestamp']) &&
             data.keys().size() <= 15;
    }

    function isValidTanod(data) {
      return data.name is string &&
             data.status in ['on-duty', 'responding', 'off-duty'] &&
             data.keys().hasAll(['name', 'status']) &&
             data.keys().size() <= 20;
    }

    function isValidIncident(data) {
      return data.tanodId == request.auth.uid &&
             data.type is string && data.type.size() <= 100 &&
             data.description is string && data.description.size() <= 5000 &&
             data.status in ['resolved', 'ongoing', 'referred'] &&
             data.keys().hasAll(['tanodId', 'tanodName', 'date', 'time', 'type', 'description', 'status', 'location']) &&
             data.keys().size() <= 15;
    }

    // ==========================================
    // SECURITY RULES
    // ==========================================

    match /{document=**} {
      allow read, write: if false;
    }

    // Residents Collection (Full Registration Profiles)
    match /residents/{resId} {
      allow get: if isSignedIn() && (resId == request.auth.uid || isAdmin() || isTanod());
      allow list: if isAdmin() || isTanod(); // Admin/Tanod can see all
      allow create: if isSignedIn() && resId == request.auth.uid && isValidResidentProfile(incoming()) && incoming().status == 'pending';
      allow update: if (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'rejectionReason', 'approvedAt'])) ||
                    (isSignedIn() && resId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'age', 'gender', 'dob', 'civilStatus', 'mobileNumber', 'altContactName', 'altContactNumber', 'houseNumber', 'street', 'householdCount', 'specialNeeds', 'specialNeedsInfo', 'gpsLat', 'gpsLng', 'lat', 'lng', 'lastSeen']));
    }

    // Users Collection (Core Auth/Role mapping)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if (userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone'])) ||
                    (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'status']));
    }

    // Tanods Collection
    match /tanods/{tanodId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidTanod(incoming());
      allow update: if (isAdmin() && isValidTanod(incoming())) || 
                    (isSignedIn() && tanodId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['lat', 'lng', 'lastSeen', 'status', 'activeAlertId'])) ||
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'activeAlertId']) && incoming().status == 'responding');
    }

    // SOS Alerts
    match /alerts/{alertId} {
      allow read: if isSignedIn() && (resource.data.residentId == request.auth.uid || isAdmin() || isTanod());
      allow create: if isSignedIn() && isValidAlert(incoming());
      allow update: if (isSignedIn() && resource.data.residentId == request.auth.uid && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
                    ((isAdmin() || isTanod()) && (
                      // Action: Dispatch
                      (existing().status == 'pending' && incoming().status == 'responding' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'respondedBy', 'respondedAt'])) ||
                      // Action: Resolve
                      (existing().status == 'responding' && incoming().status == 'resolved' && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'resolutionNotes', 'resolvedAt']))
                    ));
    }

    // Incident Reports
    match /incidents/{incidentId} {
      allow read: if isSignedIn() && (isAdmin() || isTanod());
      allow create: if isTanod() && isValidIncident(incoming());
      allow update: if isAdmin() || (isTanod() && existing().tanodId == request.auth.uid);
    }

    // Tanod Live Patrol Location
    match /patrols/{patrolId} {
      allow read: if isSignedIn();
      allow write: if isTanod() && patrolId == request.auth.uid && incoming().tanodId == request.auth.uid;
    }

    // Patrol Shifts
    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
