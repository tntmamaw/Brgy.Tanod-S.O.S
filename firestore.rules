rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    function isSignedIn() { return request.auth != null; }
    
    function isMasterAdmin() { 
      return isSignedIn() && request.auth.token.email == 'rubenlleg12@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role-based helpers using get() lookups
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserRole() == 'admin' || getUserRole() == 'superadmin'));
    }

    function isTanod() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserRole() == 'tanod'));
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin() || isOwner(userId);
    }

    // Resident Enrollment Details
    match /residents/{userId} {
      allow read: if isTanod() || isOwner(userId);
      allow write: if isMasterAdmin() || isOwner(userId);
    }

    // Emergency Alerts
    match /alerts/{alertId} {
      // Residents can only list their own alerts, Tanods/Admins can see everything
      allow read: if isSignedIn() && (isTanod() || resource.data.residentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isTanod() || resource.data.residentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Incidents (Archived/Logged alerts/reports)
    match /incidents/{incidentId} {
      allow read: if isSignedIn();
      allow write: if isTanod();
    }

    // Patrol Tracking
    match /patrols/{patrolId} {
      allow read: if isSignedIn();
      allow write: if isTanod();
    }

    // Shifts & Scheduling
    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow write: if isTanod(); // Tanods need to confirm/decline, Admins create
    }

    // Tanod Data (GPS Mirror)
    match /tanods/{tanodId} {
      allow read: if isSignedIn();
      allow write: if isTanod() || isOwner(tanodId);
    }

    // System Config & Global Siren
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isTanod(); // Both Admins and Tanods can toggle siren
    }

    // Audit Logs (Missing previously)
    match /audit_logs/{logId} {
      allow read: if isTanod();
      allow write: if isTanod();
    }
    
    // System Connection Test
    match /test/connection {
      allow read: if true;
    }

    // Global Catch-all (Deny anything else)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
