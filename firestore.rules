rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    function isSignedIn() { return request.auth != null; }
    
    function isMasterAdmin() { 
      return isSignedIn() && request.auth.token.email == 'rubenlleg12@gmail.com';
    }

    // Role-based helpers using data fields instead of recursive get() lookups 
    // where possible (or just trust the user profile read)
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // We check roles based on the 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserRole() == 'admin' || getUserRole() == 'superadmin'));
    }

    function isTanod() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserRole() == 'tanod'));
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn(); // Allow all signed in users to read profiles (needed for names/roles)
      allow write: if isMasterAdmin() || isOwner(userId);
    }

    // Resident Enrollment Details
    match /residents/{userId} {
      allow read: if isTanod() || isOwner(userId);
      allow write: if isMasterAdmin() || isOwner(userId);
    }

    // Emergency Alerts
    match /alerts/{alertId} {
      allow read: if isTanod() || (isSignedIn() && resource.data.residentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isTanod() || (isSignedIn() && resource.data.residentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Patrol Tracking
    match /patrols/{patrolId} {
      allow read: if isSignedIn();
      allow write: if isTanod() || isMasterAdmin();
    }

    // Shifts & Scheduling
    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Tanod Data (Mirror of Supabase)
    match /tanods/{tanodId} {
      allow read: if isSignedIn();
      allow write: if isTanod() || isOwner(tanodId);
    }
    
    // System Connection Test
    match /test/connection {
      allow read: if true;
    }
  }
}
